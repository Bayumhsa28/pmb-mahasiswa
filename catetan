CREATE TABLE pending_users (
    nama_lengkap TEXT,
    tanggal_lahir DATE,
    alamat TEXT,
    no_hp VARCHAR(20),

    email VARCHAR(100) PRIMARY KEY,
    password TEXT,

    gender VARCHAR(20),
    status_nikah VARCHAR(20),

    verification_code VARCHAR(6),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

